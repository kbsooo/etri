{
  "input_dir": "outputs/diffusion_encoder",
  "output_dir": "outputs/diffusion_encoder",
  "device": "mps",
  "epochs": 60,
  "batch_size": 256,
  "d_model": 128,
  "latent_dim": 64,
  "layers": 3,
  "heads": 4,
  "dropout": 0.1,
  "lr": 0.0002,
