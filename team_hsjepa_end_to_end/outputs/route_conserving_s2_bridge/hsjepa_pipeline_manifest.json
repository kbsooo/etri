      "outputs": [
        "raw/context feature artifacts used by upstream HS-JEPA modules"
      ],
      "evidence": [
        "OG records in contract: 3",
        "Required missing: 0"
      ],
      "boundary": "This stage is competition data, not external/private data."
    },
    {
      "id": "public_lb_sensor",
      "name": "Public LB Sensor Ledger",
      "role": "Uses public submission observations as a sensor for hidden row-target action response.",
      "inputs": [
        "data_analytics/hsjepa_public_score_ledger.csv"
      ],
      "outputs": [
        "public-sensitive action anchors",
        "negative toxicity anchors"
      ],
      "evidence": [
        "Ledger rows: 26",
        "Pre-public-equation best: 0.5761589494",
        "Current best: 0.5677475939"
      ],
      "boundary": "This is not an OG-only claim; it is the competition-specific sensor path."
    },
    {
      "id": "human_state_listener_context",
      "name": "Human-State Listener Context",
      "role": "Turns lifestyle/cohort context into target/cell orientation diagnostics.",
      "inputs": [
        "OG lifestyle/context artifacts",
        "s2hub_human_state_distillation_readout.json"
      ],
      "outputs": [
        "cell orientation scores",
        "human_state_probe submission"
      ],
      "evidence": [
        "Cell OOF AUC: 0.775",
        "Row OOF AUC: 0.545"
      ],
      "boundary": "Human-state is an orientation diagnostic, not a standalone row selector."
    },
    {
      "id": "og_only_assignment_probe",
      "name": "OG-only Assignment Teacher Probe",
      "role": "Tests whether human-state geometry can replace the public-sensor row-target assignment teacher.",
      "inputs": [
        "s2hub_jackpot_cell_student_frame.csv",
        "stagebridge_jackpot_cell_student_frame.csv"
      ],
      "outputs": [
        "og_only_assignment_teacher_probe_ko.md",
        "og_only_assignment_teacher_ranked_cells.csv"
      ],
      "evidence": [
        "Probe status: og_only_assignment_replacement_not_ready",
        "Pure OG row-cap2 recall: 0.0404",
        "Distilled row-cap2 recall: 0.1236"
      ],
      "boundary": "The probe currently measures the gap; it does not prove pure OG-only deployment."
    },
    {
      "id": "route_energy_model",
      "name": "Q/S Route Energy Model",
      "role": "Learns a target-route manifold from train labels and scores whether an action breaks it.",
      "inputs": [
        "train Q/S labels",
        "candidate corrected prediction vectors"
      ],
      "outputs": [
        "route energy",
        "route-conservation veto"
      ],
      "evidence": [
        "Primary route z-score: -9.66",
        "S2 route z-score: -9.46"
      ],
      "boundary": "Route energy proves candidate-pool structure, not private leaderboard safety."
    },
    {
      "id": "listener_invariant_contrastive_probe",
      "name": "Listener-Invariant Contrastive Probe",
      "role": "Tests whether listener responsibility and route-invariant action health select the same bundles.",
      "inputs": [
        "listener_responsibility_ranked_cells.csv",
        "stagebridge/s2hub candidate bundles"
      ],
      "outputs": [
        "listener_invariant_contrastive_probe_ko.md",
        "listener_invariant_contrastive_scored_bundles.csv"
      ],
      "evidence": [
        "Probe status: listener_invariant_decoder_not_ready",
        "Listener-route rho: -0.0313",
        "Contrastive overlap: 0.2152"
      ],
      "boundary": "This stage is a diagnostic; it does not create a new submission."
    },
    {
      "id": "private_safe_toxicity_probe",
      "name": "Private-Safe Toxicity Probe",
      "role": "Tests whether toxicity head generalizes across bad public anchors and selects safer cells than matched nulls.",
      "inputs": [
        "toxicity_candidate_cell_table.csv",
        "toxicity_action_audit.csv",
        "toxicity_anchor_ledger.csv"
      ],
      "outputs": [
        "private_safe_toxicity_probe_ko.md",
        "private_safe_toxicity_loo_anchor_metrics.csv"
      ],
      "evidence": [
        "Probe status: toxicity_field_promising_with_hardworld_gap",
        "Mean LOO bad-anchor AUC: 0.7880",
        "Worst LOO bad-anchor AUC: 0.3683",
        "Safety z vs matched null: 8.4589"
      ],
      "boundary": "This stage supports toxicity diagnostics, not a private-LB safety guarantee."
    },
    {
      "id": "hardworld_toxicity_factorization_probe",
      "name": "Hard-World Toxicity Factorization Probe",
      "role": "Tests whether the H088 hard-world toxicity mode is anti-correlated with broad public-bad toxicity.",
      "inputs": [
        "private_safe_toxicity_probe.json",
        "toxicity_candidate_cell_table.csv",
        "toxicity_anchor_ledger.csv"
      ],
      "outputs": [
        "hardworld_toxicity_factorization_probe_ko.md",
        "hardworld_toxicity_factorization_sectors.csv"
      ],
      "evidence": [
        "Probe status: hardworld_mixture_factorization_required",
        "Broad->H088 AUC: 0.3683",
        "Broad/H088 rho: -0.4276",
        "Joint safety z: 7.1884"
      ],
      "boundary": "This diagnostic stage says action-health should be factorized; the following decoder stage is the submission translation."
    },
    {
      "id": "factorized_toxicity_decoder_candidate",
      "name": "Factorized Toxicity Decoder Candidate",
      "role": "Translates broad-public and hard-world toxicity heads into upload-safe row-target action candidates.",
      "inputs": [
        "hardworld_toxicity_factorization_sectors.csv",
        "current best prediction",
        "public-sensitive teacher support"
      ],
      "outputs": [
        "factorized_toxicity_decoder_readout_ko.md",
        "submission_hsjepa_factorized_toxicity_decoder_teacher_dual_head_2a3c5d2d_uploadsafe.csv",
        "submission_hsjepa_factorized_toxicity_decoder_dual_safe_expansion_23b6de1e_uploadsafe.csv"
      ],
      "evidence": [
        "Decoder variants: dual_safe_expansion, teacher_dual_head",
        "Upload-safe variants: 2/2"
      ],
      "boundary": "This creates competition submissions, but their public/private score impact remains unverified until external submission."
    },
    {
      "id": "factorized_toxicity_decoder_stress_audit",
      "name": "Factorized Toxicity Decoder Stress Audit",
      "role": "Compares factorized decoder variants against target-only and source-matched feasible null action fields.",
