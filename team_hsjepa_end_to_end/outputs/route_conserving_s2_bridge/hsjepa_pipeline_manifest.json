      "outputs": [
        "hsjepa_core_manifest_ko.md",
        "hsjepa_core_ablation_contract_ko.md"
      ],
      "evidence": [
        "Core status: core_ready_for_adapter",
        "Core gates: 5/5",
        "Ablation status: ablation_contract_ready"
      ],
      "boundary": "The core must not depend on S2, public LB sensors, submission files, or manual row ids."
    },
    {
      "id": "og_raw_lifestyle_context",
      "name": "OG Raw Lifestyle Context",
      "role": "Provides train labels, submission key contract, and raw lifelog items.",
      "inputs": [
        "data/ch2026_metrics_train.csv",
        "data/ch2026_submission_sample.csv",
        "data/ch2025_data_items/*.parquet"
